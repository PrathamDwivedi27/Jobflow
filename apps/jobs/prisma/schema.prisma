generator client {
    provider = "prisma-client"
    binaryTargets = ["native", "debian-openssl-3.0.x"]
    output = "../src/generated/prisma"
    moduleFormat = "cjs"
}

datasource db {
    provider = "postgresql"
}

model Job {
    id Int @default(autoincrement()) @id
    name String 
    size Int
    completed Int
    started DateTime @default(now())
    ended DateTime?
}