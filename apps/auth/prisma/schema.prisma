generator client {
    provider = "prisma-client"
    binaryTargets = ["native", "debian-openssl-1.1.x"]
    output = "../src/generated/prisma"
    moduleFormat = "cjs"
}

datasource db {
    provider = "postgresql"
}

model User {
    id Int @default(autoincrement()) @id
    email String @unique
    password String
}