{
  "name": "jobflow-auth-e2e",
  "$schema": "../../node_modules/nx/schemas/project-schema.json",
  "projectType": "application",
  "implicitDependencies": ["jobflow-auth"],
  "targets": {
    "e2e": {
      "executor": "@nx/jest:jest",
      "outputs": ["{workspaceRoot}/coverage/{e2eProjectRoot}"],
      "options": {
        "jestConfig": "apps/jobflow-auth-e2e/jest.config.cts",
        "passWithNoTests": true
      },
      "dependsOn": ["jobflow-auth:build", "jobflow-auth:serve"]
    }
  }
}
